# 复制本文件为 .env 后填写（不要提交 .env）

# 在 https://my.telegram.org/apps 创建应用后获得
API_ID=12345678
API_HASH=你的api_hash

# 登录 Telegram 的手机号，含国家区号，例如 +8613800138000
PHONE=+86xxxxxxxxxxx

# 可选：给 Telethon 显式设置代理（推荐在中国大陆使用）
# 方式一（推荐，二选一）：PROXY_URL=socks5://127.0.0.1:7890
PROXY_URL=
# 方式二：分别填写主机端口
PROXY_TYPE=socks5
PROXY_HOST=127.0.0.1
PROXY_PORT=7890
PROXY_USERNAME=
PROXY_PASSWORD=

# 若账号开启了两步验证，填写密码；没有则留空
TELEGRAM_PASSWORD=

# 目标群：@username 或群组数字 id（如 -100xxxxxxxxxx）
# 你必须已加入该群，且能查看成员列表
TARGET_GROUP=@your_group_username

# 你的频道：@username 或频道数字 id（如 -100xxxxxxxxxx）
# 用于判断成员是否离开；离开者将从通讯录删除，并在后续不再被自动添加
TARGET_CHANNEL=

# 每次成功添加后等待的随机秒数区间（不均匀随机；默认 420-720 秒）
MIN_INTERVAL_SECONDS=420
MAX_INTERVAL_SECONDS=720

# 每小时（滚动窗口）最多成功添加的人数（默认 5）
HOURLY_MAX_ADDS=5
HOURLY_WINDOW_SECONDS=3600

# 初始化 channel_seen_ids 的策略（可选）
# INIT_CHANNEL_SEEN_FROM_DONE=false

# 频道统计（可选）：
# 开启后，脚本运行期间每隔 4 小时同步一次 channel 成员快照并打印统计：
# - 当前 channel 人数
# - 截至当前时间进入过 channel 的人数
# - 截至当前时间取消订阅（离开）的人数
ENABLE_CHANNEL_STATS=false
CHANNEL_STATS_INTERVAL_SECONDS=14400

# 统计同步时，如果发现有人离开 channel，则是否同时从通讯录删除
CHANNEL_STATS_DELETE_LEFT=true

# 跳过机器人
SKIP_BOTS=true

# 仅处理有 username 的成员（true 时无 username 的会跳过）
REQUIRE_USERNAME=false
